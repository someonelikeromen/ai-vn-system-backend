# ============================================================
# 零度叙事系统 — 环境变量配置模板
# 复制此文件为 .env 并填写你的配置
# ============================================================

# ─── 默认 LLM 提供商 ─────────────────────────────────────────
# 支持: gemini | openai | anthropic | ollama | custom
DEFAULT_LLM_PROVIDER=gemini

# ─── Gemini (默认) ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# 默认模型（写作用）: gemini-2.0-flash / gemini-1.5-pro
GEMINI_MODEL_CHRONICLER=gemini/gemini-2.0-flash
# 逻辑推理用（DM/Exchange）
GEMINI_MODEL_DM=gemini/gemini-1.5-pro
# 轻量任务（NPC/Calibrator）
GEMINI_MODEL_LIGHT=gemini/gemini-2.0-flash

# ─── OpenAI / OpenAI兼容 API ─────────────────────────────────
OPENAI_API_KEY=
# 留空则使用官方地址，填写可接入中转/本地兼容API
OPENAI_BASE_URL=

# ─── Anthropic Claude ────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Ollama 本地模型 ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ─── 自定义 OpenAI 兼容 API ───────────────────────────────────
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=

# ─── Embedding 配置 ───────────────────────────────────────────
# 支持: local | openai | custom
EMBEDDING_PROVIDER=local
# local 模式: 使用 sentence-transformers 下载的本地模型
EMBEDDING_LOCAL_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# openai/custom 模式: text-embedding-3-small / custom-embedding-model
EMBEDDING_API_MODEL=text-embedding-3-small
EMBEDDING_API_BASE_URL=
EMBEDDING_API_KEY=
# 嵌入向量维度（local=384, OpenAI text-embedding-3-small=1536）
EMBEDDING_DIMENSION=384

# ─── 数据库 ───────────────────────────────────────────────────
DB_PATH=./data/novel_system.db
CHROMADB_PATH=./data/chromadb
# ChromaDB 备选: faiss（若chromadb安装失败）
VECTOR_BACKEND=chromadb

# ─── 服务器 ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# writing-styles 目录相对后端根目录的路径（默认指向兄弟目录）
WRITING_STYLES_PATH=../../writing-styles

# ─── 系统行为 ─────────────────────────────────────────────────
# Purity Check 最大重试次数
PURITY_MAX_RETRIES=2
# 记忆提取最大队列深度（防止堆积）
EXTRACT_QUEUE_MAX=50
# 向量召回 Top-K 数量
RECALL_TOP_K=15
